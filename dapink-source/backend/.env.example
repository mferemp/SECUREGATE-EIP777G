# --- platform (do not remove) ---
BACKEND_PORT=3001
SURF_API_KEY=

# --- SecureGate: backend RPC endpoints (URLs live here ONLY, never in frontend) ---
RPC_ETH_MAINNET=
RPC_OPT_MAINNET=
RPC_POLYGON_MAINNET=
RPC_ARB_MAINNET=
RPC_BASE_MAINNET=
RPC_BNB_MAINNET=
RPC_AVAX_MAINNET=
RPC_PLASMA_MAINNET=
RPC_INK_MAINNET=
RPC_ABSTRACT_MAINNET=
RPC_ROBINHOOD_MAINNET=
RPC_ZORA_MAINNET=
RPC_LENS_MAINNET=
RPC_APECHAIN_MAINNET=
RPC_DEGEN_MAINNET=
RPC_UNICHAIN_MAINNET=
RPC_MONAD_MAINNET=
RPC_HYPERLIQUID_MAINNET=
# Deploy-disabled venues (metadata only; EVM contract deploy not applicable)
RPC_HYPERLIQUID_CORE=
RPC_SOLANA_MAINNET=

# --- anti-abuse / privacy ---
ABUSE_TRACE_PEPPER=
SESSION_SECRET=

# --- SecureGate compiled artifact (browser deploy builder) ---
SECUREGATE_BYTECODE_HEX=
SECUREGATE_ABI_JSON=[]
SECUREGATE_ARTIFACT_SHA256=
SECUREGATE_ARTIFACT_VERSION=securegate@local

# --- thank-you envelope (optional, non-recovery copy data) ---
THANK_YOU_HANDLE=@hope_ology
THANK_YOU_COPY_ADDRESS=
THANK_YOU_NETWORK=EVM
X_OAUTH2_ACCESS_TOKEN=
X_THANK_YOU_RECIPIENT_ID=

# --- durable KV (optional; memory fallback is used when unset and is NOT
#     production-durable). Set a real backend to enable durability. ---
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- testnet E2E harness (scripts/e2e-testnet-securegate.cjs).
#     These are consumed by the LOCAL script process only. Keys are NEVER sent to
#     the backend and must NEVER be committed with real values. ---
TESTNET_CHAIN_ID=
TESTNET_RPC_URL=
TESTNET_K1_PRIVATE_KEY=
TESTNET_K2_PRIVATE_KEY=
TESTNET_K2_SIGNER_MODE=
TESTNET_K3_ADDRESS=
TESTNET_TOKEN_MODE=mock
